generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String             @id @default(cuid())
  name               String?
  email              String?            @unique
  emailVerified      DateTime?
  image              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  accentColor        String             @default("#9146ff")
  twitchLogin        String?            @unique
  daSecret           String?
  accounts           Account[]
  criteria           Criteria[]         @relation("StreamerCriteria")
  criteria_templates CriteriaTemplate[]
  sessions           Session[]
  streamSessions     StreamSession[]    @relation("StreamerSessions")
  submissions        Track[]            @relation("ViewerSubmissions")
  minDonationAmount  Float              @default(50.0)
  donationCurrency   String             @default("RUB")
  donationLogs       DonationLog[]
  preferences        UserPreferences?
  wallet             Wallet?
  viewerTransactions PlatformTransaction[] @relation("ViewerTransactions")
  streamerTransactions PlatformTransaction[] @relation("StreamerTransactions")
}

model UserPreferences {
  id                  String  @id @default(cuid())
  userId              String  @unique
  language            String  @default("RU")
  theme               String  @default("Twitch Purple")
  defaultRatingSystem Json?
  isPublic            Boolean @default(true)
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StreamSession {
  id                   String               @id @default(cuid())
  streamerId           String
  status               SessionStatus        @default(ACTIVE)
  createdAt            DateTime             @default(now())
  endedAt              DateTime?
  allowDirectUploads   Boolean              @default(false)
  subOnly              Boolean              @default(false)
  allowedPlatforms     String[]             @default(["YouTube", "Spotify", "Soundcloud"])
  description          String?
  enableHighScoreSound Boolean              @default(false)
  maxAudioFileSize     Int                  @default(50)
  maxTracksPerUser     Int                  @default(1)
  overlayTheme         String               @default("DEFAULT")
  overlayToken         String?              @unique @default(cuid())
  settings             Json?
  showBpmOnOverlay     Boolean              @default(true)
  showKeyOnOverlay     Boolean              @default(true)
  slug                 String               @unique
  title                String               @default("New Stream Session")
  sessionMode          String               @default("STANDARD")
  enableNormalization  Boolean              @default(false)
  autoAdvance          Boolean              @default(true)
  trackLimit           Int?
  criteria             Criteria[]
  topTracks            HistoricalTopTrack[]
  streamer             User                 @relation("StreamerSessions", fields: [streamerId], references: [id])
  tracks               Track[]
  donations            DonationLog[]

  @@index([streamerId, status])
}

model Track {
  id          String        @id @default(cuid())
  sessionId   String
  submitterId String?
  title       String
  description String?
  lyrics      String?
  url         String?
  filePath    String?
  status      TrackStatus   @default(QUEUED)
  skipReason  String?
  submittedAt DateTime      @default(now())
  bpm         Int?          @default(0)
  key         String?       @default("")
  order       Int           @default(0)
  trackType   TrackType     @default(LINK)
  updatedAt   DateTime      @default(now()) @updatedAt
  chatScore   Float?
  isPaid      Boolean       @default(false)
  isVip       Boolean       @default(false)
  evaluations Evaluation[]
  session     StreamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  submitter   User?         @relation("ViewerSubmissions", fields: [submitterId], references: [id])

  @@index([sessionId, status])
  @@index([submitterId, sessionId])
}

model CriteriaTemplate {
  id     String @id @default(cuid())
  userId String
  name   String
  config Json
  user   User   @relation(fields: [userId], references: [id])
}

model Criteria {
  id          String         @id @default(cuid())
  streamerId  String
  name        String
  sessionId   String?
  session     StreamSession? @relation(fields: [sessionId], references: [id])
  streamer    User           @relation("StreamerCriteria", fields: [streamerId], references: [id])
  evaluations Evaluation[]
}

model Evaluation {
  id         String   @id @default(cuid())
  trackId    String
  criteriaId String
  score      Int
  criteria   Criteria @relation(fields: [criteriaId], references: [id])
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
}

model HistoricalTopTrack {
  id            String        @id @default(cuid())
  sessionId     String
  title         String
  submitterName String
  averageScore  Float
  rank          Int
  session       StreamSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId, rank])
}

enum SessionStatus {
  ACTIVE
  PAUSED
  ENDED
  ARCHIVED
  PLANNED
}

enum TrackStatus {
  QUEUED
  PLAYING
  EVALUATED
  SKIPPED
}

enum TrackType {
  LINK
  FILE
}

model DonationLog {
  id         String        @id @default(cuid())
  amount     Float
  currency   String        @default("RUB")
  username   String
  message    String?
  trackTitle String?
  streamerId String
  sessionId  String?
  createdAt  DateTime      @default(now())
  streamer   User          @relation(fields: [streamerId], references: [id])
  session    StreamSession? @relation(fields: [sessionId], references: [id])

  @@index([streamerId])
}

model PlatformTransaction {
  id          String   @id @default(cuid())
  userId      String?  
  streamerId  String   
  amount      Float
  currency    String   @default("RUB")
  status      String   @default("PENDING") 
  paymentId   String   @unique
  description String?
  metadata    Json?    
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  streamer    User     @relation("StreamerTransactions", fields: [streamerId], references: [id])
  user        User?    @relation("ViewerTransactions", fields: [userId], references: [id])
}

model Wallet {
  id         String   @id @default(cuid())
  userId     String   @unique
  balance    Float    @default(0)
  currency   String   @default("RUB")
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
